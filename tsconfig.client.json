{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals"],
    "moduleDetection": "force",
    "noEmit": true
  },
  "include": ["client/src/**/*.ts", "client/src/**/*.tsx", "vite.config.ts"]
}
