{
  "name": "sistema-gestao-jmu",
  "version": "1.0.0",
  "description": "Interface propria do Gestor JMU com frontend React e backend Fastify.",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:create-user": "tsx server/src/scripts/create-user.ts",
    "db:migrate": "tsx server/src/scripts/migrate.ts",
    "import:controle-prazos": "tsx server/src/scripts/import-controle-prazos.ts",
    "smoke:test": "tsx server/src/scripts/smoke-test.ts",
    "audit:bootstrap:vps": "node scripts/bootstrap-audit-vps.js",
    "backup:vps": "node scripts/backup-gestor-vps.js",
    "deploy:vps": "node scripts/deploy-gestor-vps.js",
    "drill:restore:vps": "node scripts/drill-restore-vps.js",
    "install:ops:vps": "node scripts/install-ops-cron-vps.js",
    "restore:vps": "node scripts/restore-gestor-vps.js",
    "rollback:vps": "node scripts/rollback-gestor-vps.js",
    "status:vps": "node scripts/status-gestor-vps.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnsonnascimento-sys/sistema-gestao-jmu.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/johnsonnascimento-sys/sistema-gestao-jmu/issues"
  },
  "homepage": "https://github.com/johnsonnascimento-sys/sistema-gestao-jmu#readme",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^8.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "axios": "^1.15.0",
    "axios-cookiejar-support": "^6.0.4",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "form-data": "^4.0.4",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.3",
    "recharts": "^3.8.0",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.5.0",
    "tough-cookie": "^5.1.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
