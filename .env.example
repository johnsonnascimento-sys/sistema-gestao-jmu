PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
SESSION_SECRET=change-me-with-at-least-16-characters
CLIENT_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
QUEUE_ATTENTION_DAYS=2
QUEUE_CRITICAL_DAYS=5
OPS_BACKUP_DIR=/backup/ops
OPS_BACKUP_SCHEMA=adminlog
OPS_EVENT_LOG_PATH=/backup/ops/operations-events.jsonl
SMOKE_TEST_REQUIRE_AUTH=false
SMOKE_TEST_REQUIRE_ADMIN=false
SMOKE_TEST_EMAIL=
SMOKE_TEST_PASSWORD=
SMOKE_TEST_ADMIN_EMAIL=
SMOKE_TEST_ADMIN_PASSWORD=
